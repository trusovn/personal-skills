diff --git a/internal/inventory/service.go b/internal/inventory/service.go
index cddf9fa..79c8fab 100644
--- a/internal/inventory/service.go
+++ b/internal/inventory/service.go
@@ -31,6 +31,23 @@ func (s *Service) Get(ctx context.Context, sku string) (Item, error) {
 	return s.repo.Get(ctx, sku)
 }
 
+func (s *Service) Reserve(ctx context.Context, sku string, quantity int) error {
+	item, _ := s.repo.Get(ctx, sku)
+
+	if item.Available < quantity {
+		return ErrInsufficientInventory
+	}
+
+	item.Available -= quantity
+	return s.repo.Update(ctx, item)
+}
+
 func (s *Service) Restock(ctx context.Context, sku string, quantity int) error {
 	return s.repo.Increment(ctx, sku, quantity)
 }
